{
  "name": "polpo",
  "version": "0.1.19",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": null,
      "./components.css": "./dist/components.css",
      "./components": {
        "types": {
          "import": "./dist/components.d.ts",
          "require": "./dist/components.d.cts"
        },
        "import": "./dist/components.js",
        "require": "./dist/components.cjs",
        "default": "./dist/components.js"
      },
      "./hooks": {
        "types": {
          "import": "./dist/hooks.d.ts",
          "require": "./dist/hooks.d.cts"
        },
        "import": "./dist/hooks.js",
        "require": "./dist/hooks.cjs",
        "default": "./dist/hooks.js"
      },
      "./layouts": {
        "types": {
          "import": "./dist/layouts.d.ts",
          "require": "./dist/layouts.d.cts"
        },
        "import": "./dist/layouts.js",
        "require": "./dist/layouts.cjs",
        "default": "./dist/layouts.js"
      },
      "./helpers": {
        "types": {
          "import": "./dist/helpers.d.ts",
          "require": "./dist/helpers.d.cts"
        },
        "import": "./dist/helpers.js",
        "require": "./dist/helpers.cjs",
        "default": "./dist/helpers.js"
      },
      "./types": {
        "types": {
          "import": "./dist/types.d.ts",
          "require": "./dist/types.d.cts"
        },
        "import": "./dist/types.js",
        "require": "./dist/types.cjs",
        "default": "./dist/types.js"
      }
    }
  },
  "exports": {
    ".": null,
    "./components.css": "./dist/components.css",
    "./components": {
      "types": "./src/components/index.ts",
      "import": "./src/components/index.ts"
    },
    "./hooks": {
      "types": "./src/hooks/index.ts",
      "import": "./src/hooks/index.ts"
    },
    "./layouts": {
      "types": "./src/layouts/index.ts",
      "import": "./src/layouts/index.ts"
    },
    "./helpers": {
      "types": "./src/helpers/index.ts",
      "import": "./src/helpers/index.ts"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "import": "./src/types/index.ts"
    }
  },
  "repository": {
    "type": "git",
    "directory": "packages/polpo",
    "url": "git+https://github.com/juanmsl/polpo-monorepo.git"
  },
  "website": "https://ui.juanmsl.com/",
  "scripts": {
    "lint": "eslint src",
    "check-types": "tsc --noEmit",
    "build": "pnpm clean && tsup",
    "clean": "rm -rf ./dist"
  },
  "devDependencies": {
    "@types/node": "*",
    "@types/react": "*",
    "@types/react-dom": "*",
    "esbuild-postcss": "^0.0.4",
    "eslint": "*",
    "polpo-eslint-config": "workspace:*",
    "polpo-typescript-config": "workspace:*",
    "postcss": "^8.5.15",
    "tsup": "*",
    "typescript": "*"
  },
  "peerDependencies": {
    "react": "*",
    "react-dom": "*",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.11"
  },
  "dependencies": {
    "polpo-tailwind-config": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "color": "^5.0.3",
    "react-colorful": "^5.7.0",
    "react-hook-form": "7.75.0",
    "react-icons": "*",
    "use-eye-dropper": "^1.7.2"
  }
}

{
  "name": "polpo",
  "version": "0.1.8",
  "sideEffects": [
    "*.css"
  ],
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": null,
    "./styles": "./dist/index.css",
    "./components": {
      "production": {
        "module": "./dist/components.js",
        "types": "./dist/components.d.ts",
        "main": "./dist/components.cjs"
      },
      "default": "./src/components/index.ts"
    },
    "./hooks": {
      "production": {
        "module": "./dist/hooks.js",
        "types": "./dist/hooks.d.ts",
        "main": "./dist/hooks.cjs"
      },
      "default": "./src/hooks/index.ts"
    },
    "./layouts": {
      "production": {
        "module": "./dist/layouts.js",
        "types": "./dist/layouts.d.ts",
        "main": "./dist/layouts.cjs"
      },
      "default": "./src/layouts/index.ts"
    },
    "./types": {
      "production": {
        "module": "./dist/types.js",
        "types": "./dist/types.d.ts",
        "main": "./dist/types.cjs"
      },
      "default": "./src/types/index.ts"
    },
    "./helpers": {
      "production": {
        "module": "./dist/helpers.js",
        "types": "./dist/helpers.d.ts",
        "main": "./dist/helpers.cjs"
      },
      "default": "./src/helpers/index.ts"
    }
  },
  "repository": {
    "type": "git",
    "directory": "packages/ui",
    "url": "git+https://github.com/juanmsl/polpo-monorepo.git"
  },
  "website": "https://ui.juanmsl.com/",
  "scripts": {
    "lint": "eslint src",
    "check-types": "tsc --noEmit",
    "build": "pnpm clean && tsup",
    "clean": "rm -rf ./dist"
  },
  "devDependencies": {
    "polpo-eslint-config": "workspace:*",
    "@polpo/tailwind-config": "workspace:*",
    "@polpo/typescript-config": "workspace:*",
    "@types/node": "*",
    "@types/react": "*",
    "@types/react-dom": "*",
    "eslint": "^9.31.0",
    "tsup": "^8.5.0",
    "typescript": "5.8.2"
  },
  "peerDependencies": {
    "react": "*",
    "react-dom": "*",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.11"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "color": "^5.0.3",
    "react-colorful": "^5.7.0",
    "react-hook-form": "7.75.0",
    "react-icons": "*",
    "use-eye-dropper": "^1.7.2"
  }
}

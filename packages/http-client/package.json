{
  "name": "polpo-http-client",
  "version": "1.1.0",
  "license": "MIT",
  "type": "module",
  "files": ["dist"],
  "exports": {
    ".": {
      "development": {
        "types": "./src/index.ts",
        "import": "./src/index.ts"
      },
      "types": {
        "import": "./src/index.ts",
        "require": "./src/index.ts"
      },
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": {
          "import": "./dist/index.d.ts",
          "require": "./dist/index.d.cts"
        },
        "import": "./dist/index.js",
        "require": "./dist/index.cjs",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "lint": "eslint src",
    "check-types": "tsc --noEmit",
    "build": "pnpm clean && tsup",
    "clean": "rm -rf ./dist",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@types/node": "*",
    "eslint": "*",
    "polpo-eslint-config": "workspace:*",
    "polpo-typescript-config": "workspace:*",
    "tsup": "*",
    "typescript": "*"
  }
}

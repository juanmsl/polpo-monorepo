{
  "name": "polpo-http-client",
  "version": "1.0.1",
  "license": "MIT",
  "type": "module",
  "files": ["dist"],
  "exports": {
    ".": {
      "production": {
        "module": "./dist/index.js",
        "types": "./dist/index.d.ts",
        "main": "./dist/index.cjs"
      },
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "lint": "eslint src",
    "check-types": "tsc --noEmit",
    "build": "pnpm clean && tsup",
    "clean": "rm -rf ./dist",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@types/node": "*",
    "eslint": "*",
    "polpo-eslint-config": "workspace:*",
    "polpo-typescript-config": "workspace:*",
    "tsup": "*",
    "typescript": "*"
  }
}

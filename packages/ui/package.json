{
  "name": "polpo",
  "version": "0.0.0",
  "sideEffects": false,
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": null,
    "./styles": "./dist/styles.css",
    "./components": "./src/components/index.ts",
    "./hooks": "./src/hooks/index.ts",
    "./helpers": "./src/helpers/index.ts",
    "./old": {
      "development": "./src/helpers/index.ts",
      "default": {
        "module": "./dist/helpers.js",
        "types": "./dist/helpers.d.ts",
        "main": "./dist/helpers.cjs"
      }
    }
  },
  "scripts": {
    "lint": "eslint src",
    "check-types": "tsc --noEmit",
    "dev:code": "tsup --watch",
    "build:code": "tsup"
  },
  "devDependencies": {
    "@polpo/eslint-config": "workspace:*",
    "@polpo/tailwind-config": "workspace:*",
    "@polpo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "@types/react": "19.1.0",
    "eslint": "^9.31.0",
    "tsup": "^8.5.0",
    "typescript": "5.8.2"
  },
  "peerDependencies": {
    "react": "^19.1.0",
    "react-icons": "^5.5.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.11"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1"
  }
}

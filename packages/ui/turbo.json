{
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["build:styles", "build:code"]
    },
    "build:styles": {
      "outputs": ["dist/**"]
    },
    "build:code": {
      "outputs": ["dist/**"]
    },
    "dev": {
      "with": ["dev:styles", "dev:code"]
    },
    "dev:styles": {
      "cache": false,
      "persistent": true
    },
    "dev:code": {
      "cache": false,
      "persistent": true
    }
  }
}

{
  "name": "polpo-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint-commit": "turbo run lint --affected -- --max-warnings 0 --cache --cache-location .turbo/cache/eslint/ --fix",
    "lint": "turbo run lint -- --max-warnings 0 --cache --cache-location .turbo/cache/eslint/",
    "lint:fix": "pnpm lint --fix",
    "check-types": "turbo run check-types",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "9.0.11",
    "turbo": "^2.7.6"
  },
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=22"
  }
}
